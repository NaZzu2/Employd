rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;
    }

    // ── Worker Profiles ─────────────────────────────────────────────────────
    match /workerProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // ── Employer Profiles ───────────────────────────────────────────────────
    match /employerProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // ── Job Posts ───────────────────────────────────────────────────────────
    match /jobPosts/{jobId} {
      // All authenticated users can read active job posts
      allow read: if request.auth != null;
      // Only the employer who created it can write/update
      allow create: if request.auth != null
        && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.employerId == request.auth.uid;
    }

    // ── Pings ───────────────────────────────────────────────────────────────
    match /pings/{pingId} {
      // Employer (recipient) and worker (sender) can both read
      allow read: if request.auth != null
        && (resource.data.workerId == request.auth.uid
            || resource.data.employerId == request.auth.uid);
      // Workers create pings
      allow create: if request.auth != null
        && request.resource.data.workerId == request.auth.uid;
      // Employer can update status (accept/decline)
      allow update: if request.auth != null
        && resource.data.employerId == request.auth.uid;
    }

    // ── Conversations ────────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read, update: if request.auth != null
        && (resource.data.employerId == request.auth.uid
            || resource.data.workerId == request.auth.uid);
      // Only employers can create conversations
      allow create: if request.auth != null
        && request.resource.data.employerId == request.auth.uid;

      // Messages sub-collection
      match /messages/{msgId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/conversations/$(convId)).data.employerId == request.auth.uid
          || get(/databases/$(database)/documents/conversations/$(convId)).data.workerId == request.auth.uid;
        allow create: if request.auth != null
          && (get(/databases/$(database)/documents/conversations/$(convId)).data.employerId == request.auth.uid
              || get(/databases/$(database)/documents/conversations/$(convId)).data.workerId == request.auth.uid)
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ── Contracts ────────────────────────────────────────────────────────────
    match /contracts/{contractId} {
      allow read: if request.auth != null
        && (resource.data.employerId == request.auth.uid
            || resource.data.workerId == request.auth.uid);
      // Employer creates contract
      allow create: if request.auth != null
        && request.resource.data.employerId == request.auth.uid;
      // Worker can update status (accept/decline); employer can mark complete
      allow update: if request.auth != null
        && (resource.data.workerId == request.auth.uid
            || resource.data.employerId == request.auth.uid);
    }

    // ── Reviews ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
    }
  }
}
